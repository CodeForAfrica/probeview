# ── Grafana Cloud Prometheus (Mimir) ─────────────────────────────────────────
# Server-side only (no NEXT_PUBLIC_ prefix) — the token is never sent to the browser.
# On Grafana Cloud, find these in Administration -> Users and access -> Cloud access policies
#
#   GRAFANA_PROM_URL : the query base URL, INCLUDING the /api/prom suffix
#   GRAFANA_PROM_USER: the numeric metrics instance ID (basic-auth username)
#   GRAFANA_PROM_TOKEN: an Access Policy token scoped `metrics:read`
GRAFANA_PROM_URL=https://prometheus-prod-XX-region.grafana.net/api/prom
GRAFANA_PROM_USER=000000
GRAFANA_PROM_TOKEN=glc_replace_me

# Force sample/fixture data even when the above are set (handy for design work):
# MOCK=1

# ── Metric name overrides ─────────────────────────────────────────────────────
# Defaults match the current Synthetic Monitoring schema. If `scripts/introspect.mjs`
# shows different names on your stack (e.g. older `probe_*`), override here.
# SM_METRIC_INFO=sm_check_info
# SM_METRIC_SUCCESS_SUM=probe_all_success_sum
# SM_METRIC_SUCCESS_COUNT=probe_all_success_count
# SM_METRIC_DURATION_SUM=probe_all_duration_seconds_sum
# SM_METRIC_DURATION_COUNT=probe_all_duration_seconds_count

# ── Thresholds, caching, branding ─────────────────────────────────────────────
# Window for the current up/down signal (reachability from the probe_all_*
# counters). Use a small multiple of your check frequency.
# CURRENT_WINDOW=1h
# UPTIME_OPERATIONAL=99.9
# UPTIME_DEGRADED=95
# REVALIDATE_SECONDS=60
# NEXT_PUBLIC_SITE_NAME=Code for Africa
# NEXT_PUBLIC_SITE_TAGLINE=Status of our public services
