{
  "name": "probeview",
  "version": "0.1.0",
  "private": true,
  "description": "A self-hostable public status page backed by Grafana Synthetic Monitoring — uptime, latency, and per-service history, configured entirely by environment variables.",
  "license": "GPL-3.0-or-later",
  "keywords": [
    "status-page",
    "uptime",
    "monitoring",
    "grafana",
    "synthetic-monitoring",
    "prometheus",
    "nextjs"
  ],
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check": "biome check --write .",
    "lint:ci": "biome ci .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "next typegen && tsc -p tsconfig.test.json --noEmit",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^6",
    "vitest": "^4.1.9"
  }
}
